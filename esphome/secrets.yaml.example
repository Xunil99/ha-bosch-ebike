# Copy this file to `secrets.yaml` in the same folder as your bridge YAML and
# fill in your real values. Do NOT commit secrets.yaml to git.
#
# Used by example-bridge-mobile.yaml. The plain example-bridge.yaml (native
# API) only needs wifi_ssid / wifi_password.

# --- Home WiFi --------------------------------------------------------------
wifi_ssid: "YourHomeWiFi"
wifi_password: "your-home-wifi-password"

# --- Phone hotspot (mobile / roaming use) -----------------------------------
# iPhone: Settings > Personal Hotspot > "Maximize Compatibility" must be ON.
# That forces the hotspot to 2.4 GHz; the ESP32 has no 5 GHz radio and would
# otherwise never see the hotspot.
hotspot_ssid: "YourPhoneHotspot"
hotspot_password: "your-hotspot-password"

# --- MQTT broker (e.g. the Mosquitto add-on in Home Assistant) --------------
mqtt_broker: "192.168.2.10"
mqtt_user: "your-mqtt-user"
mqtt_password: "your-mqtt-password"

# --- WireGuard --------------------------------------------------------------
# All of these come from the WireGuard connection you create in your router
# (FritzBox: Internet > Permit Access > VPN (WireGuard)). See MOBILE.md.
#
# wg_address: the IP the router ASSIGNS to this peer (the ESP). It must match
#             exactly, and it usually sits inside your home subnet.
wg_address: "192.168.2.203"
# wg_endpoint / wg_port: your router's public hostname and the WireGuard port.
wg_endpoint: "yourbox.myfritz.net"
wg_port: 51820
# Keys: the router generates a key pair for the peer. The PRIVATE key goes
# here (to the ESP); the router's PUBLIC key goes into wg_peer_public_key.
wg_private_key: "your-peer-private-key"
wg_peer_public_key: "the-routers-public-key"
wg_preshared_key: "the-preshared-key"
# wg_allowed_subnet: your home subnet, so only HA traffic uses the tunnel
# (split tunnel) and normal internet stays on the hotspot.
wg_allowed_subnet: "192.168.2.0/24"
